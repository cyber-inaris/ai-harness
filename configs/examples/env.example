# Copy to .env locally or map these through your secret manager.
FREEMODEL_API_KEY=
LIGHTNINGZEUS_API_KEY=
TRUSTED_JUDGE_API_KEY=

# Provider Telegram binding state.
# Local default is data/provider-bindings.sqlite; server/Hermes should use /var/lib.
AI_HARNESS_BINDINGS_DB=/var/lib/ai-harness/provider-bindings.sqlite
AI_HARNESS_EXECUTOR=hermes-server

# SSPanel Telegram executor access. Prefer a short-lived token if available.
SSPANEL_BASE_URL=http://localhost:3000
SSPANEL_ADMIN_EMAIL=
SSPANEL_ADMIN_PASSWORD=
SSPANEL_ADMIN_TOKEN=
