# Heat guard thresholds in Celsius.
AI_HARNESS_HEAT_WARN_TEMP_C=80
AI_HARNESS_HEAT_CRIT_TEMP_C=88

# User that owns the interactive Firefox session on the host.
AI_HARNESS_HEAT_FIREFOX_USER=dima

# Set to 0 on hosts where thermald exits with unsupported CPU/platform.
AI_HARNESS_HEAT_START_THERMALD=1

# Keep this disabled by default. When set to 1, critical temperature can
# terminate the whole Firefox process for the configured user. The script does
# not try to close individual tabs because Firefox tab control is not reliable
# without a dedicated remote-debugging/browser-control setup.
AI_HARNESS_HEAT_RESTART_FIREFOX=0

AI_HARNESS_HEAT_LOG_DIR=/var/log/ai-harness
