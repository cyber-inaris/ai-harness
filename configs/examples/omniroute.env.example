# Copy to /opt/ai-harness/secrets/omniroute.env on the host.
# Do not commit real provider credentials.

NODE_ENV=production
PORT=20128
HOSTNAME=0.0.0.0
DATA_DIR=/app/data

# Optional local router API key if OmniRoute is configured to require one.
# OMNIROUTE_API_KEY=sk_omniroute

# Provider keys belong here only on the host, never in git.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
